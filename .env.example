# Lumen API keys
# Keys are read in priority: env var > config.yaml
# Set your keys here, then run: cp .env.example .env
#
# If you run `lumen init`, API keys are written to .env automatically.

DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# OPENROUTER_API_KEY=sk-or-v1-your-key-here  # alternative for OpenRouter
# CLAUDE_API_KEY=sk-ant-your-claude-key-here
